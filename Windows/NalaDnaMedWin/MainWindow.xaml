<Window
    x:Class="NalaDnaMedWin.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="NALA-DNA-Med (Windows Edition)">

    <Grid Background="#FF0C0C0C">
        <NavigationView x:Name="NavView" 
                        IsBackButtonVisible="Collapsed" 
                        PaneDisplayMode="Left"
                        ItemInvoked="NavView_ItemInvoked">
            <NavigationView.MenuItems>
                <NavigationViewItem x:Name="NavDashboard" Icon="Home" Content="Dashboard" Tag="Dashboard" />
                <NavigationViewItem x:Name="NavLLMFit" Icon="Find" Content="LLM-Fit Advisor" Tag="LLMFit" />
                <NavigationViewItem x:Name="NavProjects" Icon="Library" Content="Projects / Vaults" Tag="Projects" />
                <NavigationViewItem x:Name="NavUpload" Icon="Upload" Content="Upload Center" Tag="Upload" />
                <NavigationViewItem x:Name="NavBioLab" Icon="Find" Content="BioLab Demo" Tag="BioLab" />
                <NavigationViewItem x:Name="NavJobs" Icon="PreviewLink" Content="Jobs / Audit" Tag="Jobs" />
                <NavigationViewItem x:Name="NavResources" Icon="List" Content="Resources" Tag="Resources" />
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <NavigationViewItem x:Name="NavSettings" Icon="Setting" Content="Settings" Tag="Settings" />
            </NavigationView.FooterMenuItems>
            
            <Frame x:Name="ContentFrame" Padding="24">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="20">
                    <Image Source="Assets/appicon.png" Width="200" Height="200" />
                    <TextBlock x:Name="WelcomeTitleTextBlock" Text="Welcome to NALA-DNA-Med" FontSize="32" FontWeight="Bold" Foreground="#FF00FF88" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="WelcomeSubtitleTextBlock" Text="Native WinUI 3 Client - Local Lite Mode" FontSize="18" Foreground="#FFCCCCCC" HorizontalAlignment="Center"/>
                    <Border Background="#20FF0000" BorderBrush="#80FF0000" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,20,0,0">
                        <StackPanel>
                            <TextBlock x:Name="WelcomeWarningTitleTextBlock" Text="! NOT MEDICAL ADVICE !" FontWeight="Bold" Foreground="#FFFF4444" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="WelcomeWarningSubtitleTextBlock" Text="This software is for research support only. It is not a medical device." Foreground="#FFFF8888" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Frame>
        </NavigationView>
    </Grid>
</Window>
