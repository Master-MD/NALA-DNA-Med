<Page
    x:Class="NalaDnaMedWin.Views.UploadPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <StackPanel Spacing="16">
            <TextBlock Text="Upload Center" FontSize="28" FontWeight="SemiBold" Foreground="#FF00FF88" />
            <TextBlock Text="Local placeholders for biomedical files (PDF, CSV, FASTA, SMILES)." FontSize="14" Foreground="#FF888888" />

            <Border Background="#20FFFF00" BorderBrush="#80FFFF00" BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <FontIcon Glyph="&#xE7BA;" Foreground="#FFFFD700" />
                    <TextBlock Text="CAVEMAN mode keeps uploads entirely local in v0.1." Foreground="#FFFFD700" FontWeight="SemiBold" VerticalAlignment="Center" />
                </StackPanel>
            </Border>

            <!-- Drag & Drop Area -->
            <Border Background="#11FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="2" BorderStrokeBehavior="OutsideImage" CornerRadius="12" Padding="40" Margin="0,20,0,0" Height="200">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12">
                    <FontIcon Glyph="&#xE8B5;" FontSize="48" Foreground="#FF00FF88" />
                    <TextBlock Text="Drag and drop your molecular or literature files here" FontSize="16" Foreground="#FFCCCCCC" HorizontalAlignment="Center" />
                    <TextBlock Text="or click below to choose files" FontSize="12" Foreground="#FF888888" HorizontalAlignment="Center" />
                    <Button Content="Choose Files..." Click="ChooseFiles_Click" Background="#FF00FF88" Foreground="#FF000000" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,10,0,0" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="UploadStatusTextBlock" Text="" Foreground="#FF00FF88" FontSize="14" Margin="0,10,0,0" />
        </StackPanel>
    </Grid>
</Page>
