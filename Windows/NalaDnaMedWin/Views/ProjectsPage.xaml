<Page
    x:Class="NalaDnaMedWin.Views.ProjectsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <StackPanel Spacing="16">
            <TextBlock Text="Projects / Vaults" FontSize="28" FontWeight="SemiBold" Foreground="#FF00FF88" />
            <TextBlock Text="Manage secure, tenant-isolated research workspaces." FontSize="14" Foreground="#FF888888" />

            <Button Content="Create New Vault" Click="CreateVault_Click" Background="#FF00FF88" Foreground="#FF000000" FontWeight="Bold" />

            <StackPanel x:Name="VaultsListPanel" Spacing="12" Margin="0,16,0,0">
                <!-- Vault Item 1 -->
                <Border Background="#11FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Autoimmune Bio-Regeneration Research" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFFFF" />
                        <TextBlock Text="Focused on Rheumatism and Colitis Ulcerosa cell repair pathway modeling." FontSize="14" Foreground="#FFCCCCCC" Margin="0,4,0,0" />
                        <TextBlock Text="Tenant ID: tenant-882-lite  |  Vault ID: vault-909" FontSize="11" Foreground="#FF888888" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
                <!-- Vault Item 2 -->
                <Border Background="#11FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="8" Padding="16">
                    <StackPanel>
                        <TextBlock Text="Regenerative Biology (Axolotl Blastema)" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFFFF" />
                        <TextBlock Text="Literature review and target analysis for bone/limb cell regrowth signaling." FontSize="14" Foreground="#FFCCCCCC" Margin="0,4,0,0" />
                        <TextBlock Text="Tenant ID: tenant-882-lite  |  Vault ID: vault-104" FontSize="11" Foreground="#FF888888" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
