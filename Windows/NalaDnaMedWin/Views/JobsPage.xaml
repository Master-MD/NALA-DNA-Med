<Page
    x:Class="NalaDnaMedWin.Views.JobsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="24">
        <StackPanel Spacing="16">
            <TextBlock Text="Jobs / Audit Trail" FontSize="28" FontWeight="SemiBold" Foreground="#FF00FF88" />
            <TextBlock Text="Local secure logging of all data operations and model evaluations." FontSize="14" Foreground="#FF888888" />

            <StackPanel Spacing="10" Margin="0,10,0,0">
                <Border Background="#11FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="8" Padding="12">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Fill="#FF00FF88" Width="12" Height="12" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="BioLab analysis simulated" FontWeight="SemiBold" Foreground="#FFFFFFFF" />
                            <TextBlock Text="Validated TenantShield criteria for local research demo." FontSize="12" Foreground="#FF888888" />
                        </StackPanel>
                        <TextBlock Grid.Column="3" Text="Success" Foreground="#FF00FF88" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Background="#11FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="8" Padding="12">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Fill="#FF00FF88" Width="12" Height="12" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="TenantShield context established" FontWeight="SemiBold" Foreground="#FFFFFFFF" />
                            <TextBlock Text="Initial setup of local secure boundary done." FontSize="12" Foreground="#FF888888" />
                        </StackPanel>
                        <TextBlock Grid.Column="3" Text="Success" Foreground="#FF00FF88" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Background="#11FFFFFF" BorderBrush="#33FFFFFF" BorderThickness="1" CornerRadius="8" Padding="12">
                    <Grid ColumnSpacing="16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Grid.Column="0" Fill="#FF00FF88" Width="12" Height="12" VerticalAlignment="Center" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="System hardware checked" FontWeight="SemiBold" Foreground="#FFFFFFFF" />
                            <TextBlock Text="Identified CPU, Memory, and Disk constraints for local execution." FontSize="12" Foreground="#FF888888" />
                        </StackPanel>
                        <TextBlock Grid.Column="3" Text="Success" Foreground="#FF00FF88" VerticalAlignment="Center" />
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Support Report Copy Section -->
            <TextBlock Text="Generate Technical Support Report" FontSize="18" FontWeight="SemiBold" Foreground="#FFFFFFFF" Margin="0,20,0,0" />
            <TextBlock Text="Generates a local configuration trace to help non-technical advisors troubleshoot. No personal data is exported." FontSize="14" Foreground="#FF888888" />
            <Button Content="Copy Support Report to Clipboard" Click="CopySupportReport_Click" Background="#FF00FF88" Foreground="#FF000000" FontWeight="Bold" Margin="0,6,0,0" />
            <TextBlock x:Name="SupportReportStatusTextBlock" Text="" Foreground="#FF00FF88" FontSize="14" />
        </StackPanel>
    </Grid>
</Page>
